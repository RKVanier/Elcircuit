<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="800.0" 
            xmlns="http://javafx.com/javafx/25" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="elcicruit.CircuitBuilderController"
            style="-fx-background-color: #f5f5f5;">
   
   <top>
      <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
         <children>
            <Label text="Circuit Diagram" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <Label text="Visual representation of your circuit components" textFill="#ecf0f1">
               <font>
                  <Font size="12.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </top>
   
   <center>
      <Canvas fx:id="circuitCanvas" 
              height="500.0" 
              width="780.0" 
              style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 2);"
              BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </BorderPane.margin>
      </Canvas>
   </center>
   
   <bottom>
      <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #ecf0f1; -fx-padding: 10;">
         <children>
            <Label text="💡 Tip: Add or modify components in the Circuit Calculator" style="-fx-text-fill: #34495e;">
               <font>
                  <Font size="11.0" />
               </font>
            </Label>
            <Label text="The diagram updates automatically when you change values" style="-fx-text-fill: #7f8c8d;">
               <font>
                  <Font size="10.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </bottom>
   
</BorderPane>